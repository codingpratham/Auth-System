generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int            @id @default(autoincrement())
  email    String         @unique
  name     String?
  password String         
  token    RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id],onDelete:Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
